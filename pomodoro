            return
        notify(cfg, "What did you learn today?", "Jot down one thing before the day ends.")
        return
    if sub == "recall":
        print(json.dumps(recall_learning()))
        return
    print(f"unknown learning subcommand: {sub}", file=sys.stderr)
    sys.exit(1)


