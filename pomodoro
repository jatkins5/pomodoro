def recall_learning(today: date | None = None) -> dict:
    """Pick one past learning to resurface today.

    Eligible entries are those logged before the start of the current
    Sun-Sat week (i.e. from a previous week, not this one). The choice is
    deterministic per day so it stays put while a tab is open and rotates
    the next morning, the same trick `motd current` uses.
    """
    today = today or date.today()
    # Start (Sunday) of the current week. weekday(): Mon=0 .. Sun=6.
    week_start = today - timedelta(days=(today.weekday() + 1) % 7)
    cutoff = week_start.isoformat()
    eligible = [
        e for e in load_learnings()
        if (e.get("ts", "")[:10]) and e["ts"][:10] < cutoff
    ]
    if not eligible:
        return {}
    idx = int(hashlib.sha1(today.isoformat().encode()).hexdigest(), 16) % len(eligible)
    e = eligible[idx]
    return {"id": e.get("id"), "text": e.get("text", ""), "ts": e.get("ts", ""), "date": e["ts"][:10]}


