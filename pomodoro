def _fetch_text(url: str) -> str:
    """Fetch a URL and return its visible text (stdlib only)."""
    import urllib.request
    from html.parser import HTMLParser

    class _Extractor(HTMLParser):
        SKIP = {"script", "style", "head", "noscript", "svg", "template"}

        def __init__(self):
            super().__init__()
            self.parts: list[str] = []
            self._skip = 0

        def handle_starttag(self, tag, attrs):
            if tag in self.SKIP:
                self._skip += 1

        def handle_endtag(self, tag):
            if tag in self.SKIP and self._skip:
                self._skip -= 1

        def handle_data(self, data):
            if not self._skip:
                text = data.strip()
                if text:
                    self.parts.append(text)

    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0 (pomodoro motd)"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        charset = resp.headers.get_content_charset() or "utf-8"
        html = resp.read().decode(charset, errors="replace")
    parser = _Extractor()
    parser.feed(html)
    text = re.sub(r"\n{3,}", "\n\n", "\n".join(parser.parts))
    return text[:40000]


def _loads_lenient(content: str) -> dict:
    """Parse a JSON object that may be wrapped in prose or ```json fences."""
    content = content.strip()
    if content.startswith("```"):
        content = re.sub(r"^```[a-zA-Z]*\n?|\n?```$", "", content).strip()
    try:
        return json.loads(content)
    except json.JSONDecodeError:
        m = re.search(r"\{.*\}", content, re.DOTALL)
        if m:
            return json.loads(m.group(0))
        raise


def _load_dotenv() -> None:
    """Load KEY=VALUE pairs from a repo-local .env (without overriding real env)."""
    path = Path(__file__).resolve().parent / ".env"
    if not path.exists():
        return
    for line in path.read_text().splitlines():
        line = line.strip()
        if line.startswith("export "):
            line = line[len("export "):]
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if key and key not in os.environ:
            os.environ[key] = val


def _extract_snippets(cfg: dict, url: str, text: str) -> dict:
    """Extract key passages via an OpenRouter (OpenAI-compatible) chat model.

    Returns {"title": str, "snippets": [{"phrase","context","why"}, ...]}.
    Uses stdlib urllib — no third-party packages.
    """
    import urllib.error
    import urllib.request

    _load_dotenv()
    api_key = os.environ.get("OPENROUTER_API_KEY")
    if not api_key:
        raise RuntimeError("motd build needs OPENROUTER_API_KEY in the environment")

    schema = {
        "type": "object",
        "properties": {
            "title": {"type": "string"},
            "snippets": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "phrase": {"type": "string"},
                        "context": {"type": "string"},
                        "why": {"type": "string"},
                    },
                    "required": ["phrase", "context", "why"],
                    "additionalProperties": False,
                },
            },
        },
        "required": ["title", "snippets"],
        "additionalProperties": False,
    }
    payload = {
        "model": cfg.get("motd_model", "anthropic/claude-sonnet-4.6"),
        "max_tokens": 8000,
        "messages": [
            {"role": "system", "content": MOTD_SYSTEM},
            {"role": "user", "content": f"Source URL: {url}\n\n{text}"},
        ],
        "response_format": {
            "type": "json_schema",
            "json_schema": {"name": "extraction", "strict": True, "schema": schema},
        },
    }
    base = cfg.get("motd_base_url", "https://openrouter.ai/api/v1").rstrip("/")
    req = urllib.request.Request(
        f"{base}/chat/completions",
        data=json.dumps(payload).encode(),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "X-Title": "pomodoro motd",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")[:500]
        raise RuntimeError(f"OpenRouter HTTP {e.code}: {body}") from e
    try:
        content = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError) as e:
        raise RuntimeError(f"unexpected OpenRouter response: {json.dumps(data)[:300]}") from e
    return _loads_lenient(content)


def cmd_motd(cfg: dict, args: list[str]) -> None:
    if not args:
        print("usage: pomodoro motd {add|sources|remove|build|current}", file=sys.stderr)
