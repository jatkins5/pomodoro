#!/usr/bin/env python3
"""Custom pomodoro timer with i3blocks integration.

Subcommands:
  toggle      Start, pause, or resume the timer.
  stop        Cancel the current pomodoro entirely.
  skip        Skip the current phase and advance to the next.
  reset       Restart the current phase from the beginning.
  status      Print human-readable status.
  status --json
  status --i3blocks   Three-line output for i3blocks.
  analyze [--today|--week|--all]   Summarize the log.
  notifications [--since-id N]     Show muted notification backlog in rofi.
  pause-reason [--duration N]      Prompt for a reason for the last pause; logged.
  tasks list [--include-completed] [--tag NAME]
  tasks add                        Read JSON body from stdin: {title, due_at?, scheduled_at?, long_term?, notes?}
                                   #tags in the title are parsed out and stored as tags.
  tasks update <id>                Read JSON body from stdin with fields to merge (null clears).
  tasks complete <id>
  tasks uncomplete <id>
  tasks delete <id>
  set-task                         Read JSON body from stdin: {task_id} | {task_text} | {clear: true}

Config:  ~/.config/pomodoro/config.json (auto-created with defaults)
State:   ~/.local/state/pomodoro/state.json
Tasks:   ~/.local/state/pomodoro/tasks.json
Log:     ~/.local/state/pomodoro/log.jsonl
"""

import json
import os
import re
import shutil
import subprocess
import sys
import time
from collections import defaultdict
from datetime import date, datetime, timedelta
from pathlib import Path

CONFIG_PATH = Path(
    os.environ.get("POMODORO_CONFIG")
    or Path.home() / ".config" / "pomodoro" / "config.json"
)
STATE_DIR = Path(
    os.environ.get("POMODORO_STATE_DIR")
    or Path.home() / ".local" / "state" / "pomodoro"
)
STATE_PATH = STATE_DIR / "state.json"
LOG_PATH = STATE_DIR / "log.jsonl"
TASKS_PATH = STATE_DIR / "tasks.json"
MUTE_MARKER = STATE_DIR / "mute_since_id"
MEDIA_MARKER = STATE_DIR / "paused_media"

DEFAULTS = {
    "focus_minutes": 25,
    "short_break_minutes": 5,
    "long_break_minutes": 15,
    "cycle_length": 4,
    "auto_advance": True,
    "notify": True,
    "colors": {
        "focus": "#FF6B6B",
        "short_break": "#51CF66",
        "long_break": "#339AF0",
        "paused": "#F59F00",
    },
}


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
        CONFIG_PATH.write_text(json.dumps(DEFAULTS, indent=2) + "\n")
        return dict(DEFAULTS)
    cfg = json.loads(CONFIG_PATH.read_text())
    merged = {**DEFAULTS, **cfg}
    merged["colors"] = {**DEFAULTS["colors"], **cfg.get("colors", {})}
    return merged


def load_state() -> dict | None:
    if not STATE_PATH.exists():
        return None
    return json.loads(STATE_PATH.read_text())


def save_state(state: dict | None) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if state is None:
        STATE_PATH.unlink(missing_ok=True)
        return
    tmp = STATE_PATH.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2))
    tmp.replace(STATE_PATH)


def iso(epoch: float) -> str:
    return datetime.fromtimestamp(epoch).astimezone().isoformat(timespec="seconds")


def now_iso() -> str:
    return iso(time.time())


def log_event(event: str, **fields) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    entry = {"ts": now_iso(), "event": event, **fields}
    with LOG_PATH.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def phase_seconds(cfg: dict, phase: str) -> int:
    return int(cfg[f"{phase}_minutes"] * 60)


def notify(cfg: dict, summary: str, body: str = "") -> None:
    if not cfg.get("notify", True):
        return
    if not shutil.which("notify-send"):
        return
    subprocess.Popen(
        ["notify-send", "-a", "Pomodoro", "--", summary, body],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def _dunstctl(*args: str) -> tuple[int, str]:
    if not shutil.which("dunstctl"):
        return 1, ""
    r = subprocess.run(
        ["dunstctl", *args], capture_output=True, text=True
    )
    return r.returncode, r.stdout


def _dunst_history() -> list[dict]:
    rc, out = _dunstctl("history")
    if rc != 0:
        return []
    try:
        return json.loads(out).get("data", [[]])[0]
    except (json.JSONDecodeError, IndexError, AttributeError):
        return []


def _max_history_id() -> int:
    return max(
        (n.get("id", {}).get("data", 0) for n in _dunst_history()),
        default=0,
    )


def enable_focus_mute() -> None:
    if not shutil.which("dunstctl"):
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if not MUTE_MARKER.exists():
        MUTE_MARKER.write_text(str(_max_history_id()))
    _dunstctl("rule", "focus_mute", "enable")


def disable_focus_mute(show_backlog: bool = False) -> None:
    if not shutil.which("dunstctl"):
        return
    _dunstctl("rule", "focus_mute", "disable")
    if not MUTE_MARKER.exists():
        return
    try:
        baseline = int(MUTE_MARKER.read_text().strip())
    except ValueError:
        baseline = 0
    MUTE_MARKER.unlink(missing_ok=True)
    if show_backlog and shutil.which("rofi"):
        subprocess.Popen(
            [str(Path(__file__).resolve()), "notifications",
             "--since-id", str(baseline)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )


def _apply_mute_for_phase(phase: str) -> None:
    if phase == "focus":
        enable_focus_mute()
    else:
        disable_focus_mute(show_backlog=True)


def _playerctl(*args: str) -> tuple[int, str]:
    if not shutil.which("playerctl"):
        return 1, ""
    r = subprocess.run(
        ["playerctl", *args], capture_output=True, text=True
    )
    return r.returncode, r.stdout


def _playing_players() -> list[str]:
    rc, out = _playerctl("--all-players", "-f", "{{playerName}}|{{status}}", "status")
    if rc != 0:
        return []
    playing = []
    for line in out.splitlines():
        line = line.strip()
        if not line or "|" not in line:
            continue
        name, _, status = line.rpartition("|")
        if status == "Playing" and name:
            playing.append(name)
    return playing


def pause_active_media() -> None:
    if not shutil.which("playerctl"):
        return
    players = _playing_players()
    if not players:
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    MEDIA_MARKER.write_text(json.dumps(players))
    for p in players:
        _playerctl("--player", p, "pause")


def resume_paused_media() -> None:
    if not shutil.which("playerctl") or not MEDIA_MARKER.exists():
        return
    try:
        players = json.loads(MEDIA_MARKER.read_text())
    except (json.JSONDecodeError, OSError):
        players = []
    MEDIA_MARKER.unlink(missing_ok=True)
    for p in players:
        _playerctl("--player", p, "play")


def _apply_media_for_phase(phase: str) -> None:
    if phase in ("short_break", "long_break"):
        pause_active_media()
    else:
        resume_paused_media()


def next_phase(state: dict, cfg: dict) -> tuple[str, int]:
    completed = state.get("completed_focuses", 0)
    if state["phase"] == "focus":
        completed += 1
        if completed % int(cfg["cycle_length"]) == 0:
            return "long_break", completed
        return "short_break", completed
    return "focus", completed


def remaining(state: dict, cfg: dict) -> int:
    if state.get("paused_at") is not None:
        return int(state["remaining_at_pause"])
    elapsed = time.time() - state["phase_started_epoch"]
    return max(0, phase_seconds(cfg, state["phase"]) - int(elapsed))


def advance_if_done(state: dict, cfg: dict) -> dict | None:
    while state is not None and state.get("paused_at") is None and remaining(state, cfg) == 0:
        ended = state["phase"]
        ended_dur = phase_seconds(cfg, ended)
        prev_task_id = state.get("task_id")
        prev_task_text = state.get("task_text")
        log_event(
            "phase_end",
            phase=ended,
            completed_focuses=state.get("completed_focuses", 0)
            + (1 if ended == "focus" else 0),
            task_id=prev_task_id,
            task_text=prev_task_text,
        )
        np, completed = next_phase(state, cfg)
        if cfg.get("auto_advance", True):
            new_start = state["phase_started_epoch"] + ended_dur
            state = {
                "phase": np,
                "phase_started_epoch": new_start,
                "completed_focuses": completed,
                "paused_at": None,
                "remaining_at_pause": None,
                "task_id": prev_task_id,
                "task_text": prev_task_text,
            }
            log_event("phase_start", phase=np, completed_focuses=completed, task_id=prev_task_id, task_text=prev_task_text)
            notify(
                cfg,
                f"{ended.replace('_', ' ').title()} complete",
                f"Starting {np.replace('_', ' ')}",
            )
            _apply_mute_for_phase(np)
            _apply_media_for_phase(np)
        else:
            log_event("stop_auto", phase=ended, completed_focuses=completed)
            notify(cfg, f"{ended.replace('_', ' ').title()} complete", "Pomodoro stopped")
            disable_focus_mute(show_backlog=(ended == "focus"))
            resume_paused_media()
            state = None
            break
    save_state(state)
    return state


def cmd_toggle(cfg: dict) -> None:
    state = load_state()
    if state is None:
        body = read_stdin_json()
        task_id = body.get("task_id")
        try:
            task_id = int(task_id) if task_id is not None else None
        except (ValueError, TypeError):
            task_id = None
        task_text = body.get("task_text")
        task_text = str(task_text).strip() if task_text else None
        if task_id is not None:
            task_text = None
        new = {
            "phase": "focus",
            "phase_started_epoch": time.time(),
            "completed_focuses": 0,
            "paused_at": None,
            "remaining_at_pause": None,
            "task_id": task_id,
            "task_text": task_text,
        }
        save_state(new)
        log_event("start", phase="focus", task_id=task_id, task_text=task_text)
        notify(cfg, "Pomodoro started", "Focus 1")
        enable_focus_mute()
        return
    state = advance_if_done(state, cfg)
    if state is None:
        cmd_toggle(cfg)
        return
    if state.get("paused_at") is None:
        rem = remaining(state, cfg)
        state["remaining_at_pause"] = rem
        state["paused_at"] = time.time()
        save_state(state)
        log_event("pause", phase=state["phase"], remaining=rem)
        notify(cfg, "Pomodoro paused", f"{state['phase'].replace('_', ' ')} — {fmt_mmss(rem)} left")
        disable_focus_mute(show_backlog=False)
    else:
        pause_dur = time.time() - state["paused_at"]
        state["phase_started_epoch"] += pause_dur
        state["paused_at"] = None
        state["remaining_at_pause"] = None
        save_state(state)
        log_event("resume", phase=state["phase"], pause_duration=int(pause_dur))
        notify(cfg, "Pomodoro resumed", state["phase"].replace("_", " "))
        if state["phase"] == "focus":
            enable_focus_mute()
        if int(pause_dur) > 10 and shutil.which("rofi"):
            subprocess.Popen(
                [str(Path(__file__).resolve()), "pause-reason",
                 "--duration", str(int(pause_dur))],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )


def cmd_stop(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    log_event(
        "stop",
        phase=state["phase"],
        completed_focuses=state.get("completed_focuses", 0),
        remaining=remaining(state, cfg),
        task_id=state.get("task_id"),
        task_text=state.get("task_text"),
    )
    save_state(None)
    notify(cfg, "Pomodoro stopped")
    disable_focus_mute(show_backlog=False)
    resume_paused_media()


def cmd_skip(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    ended = state["phase"]
    completed_so_far = state.get("completed_focuses", 0) + (1 if ended == "focus" else 0)
    log_event("skip", phase=ended, completed_focuses=completed_so_far)
    np, completed = next_phase(state, cfg)
    new = {
        "phase": np,
        "phase_started_epoch": time.time(),
        "completed_focuses": completed,
        "paused_at": None,
        "remaining_at_pause": None,
        "task_id": state.get("task_id"),
        "task_text": state.get("task_text"),
    }
    save_state(new)
    log_event("phase_start", phase=np, completed_focuses=completed, task_id=new.get("task_id"), task_text=new.get("task_text"))
    notify(cfg, f"Skipped to {np.replace('_', ' ')}")
    _apply_mute_for_phase(np)
    _apply_media_for_phase(np)


def cmd_reset(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    log_event("reset", phase=state["phase"])
    state["phase_started_epoch"] = time.time()
    if state.get("paused_at") is not None:
        state["paused_at"] = time.time()
        state["remaining_at_pause"] = phase_seconds(cfg, state["phase"])
    save_state(state)
    notify(cfg, f"{state['phase'].replace('_', ' ').title()} reset")
    if state["phase"] == "focus":
        enable_focus_mute()


def fmt_mmss(seconds: int) -> str:
    m, s = divmod(int(seconds), 60)
    return f"{m:02d}:{s:02d}"


def focuses_completed_on(date_str: str) -> int:
    if not LOG_PATH.exists():
        return 0
    count = 0
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line or not line.startswith("{"):
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            if (
                e.get("event") == "phase_end"
                and e.get("phase") == "focus"
                and e.get("ts", "").startswith(date_str)
            ):
                count += 1
    return count


def cmd_status(cfg: dict, mode: str) -> None:
    state = load_state()
    if state is not None:
        state = advance_if_done(state, cfg)
    today = datetime.now().date().isoformat()
    focuses_today = focuses_completed_on(today)
    if state is None:
        if mode == "json":
            print(json.dumps({"status": "idle", "focuses_today": focuses_today, "task": None}))
        elif mode == "i3blocks":
            pass
        else:
            print(f"idle ({focuses_today} today)" if focuses_today else "idle")
        return
    rem = remaining(state, cfg)
    paused = state.get("paused_at") is not None
    color = cfg["colors"]["paused"] if paused else cfg["colors"][state["phase"]]
    text = fmt_mmss(rem)
    if mode == "json":
        print(json.dumps({
            "status": "paused" if paused else "running",
            "phase": state["phase"],
            "remaining": rem,
            "text": text,
            "color": color,
            "completed_focuses": state.get("completed_focuses", 0),
            "cycle_length": int(cfg["cycle_length"]),
            "focuses_today": focuses_today,
            "task": resolve_active_task(state, load_tasks()),
        }))
    elif mode == "i3blocks":
        print(text)
        print(text)
        print(color)
    else:
        cycle = int(cfg["cycle_length"])
        done = state.get("completed_focuses", 0)
        label = state["phase"].replace("_", " ")
        suffix = " (paused)" if paused else ""
        print(f"{label} {text} — {done % cycle if state['phase'] == 'focus' else done}/{cycle}{suffix}")


def cmd_analyze(args: list[str]) -> None:
    if not LOG_PATH.exists():
        print("No log yet.")
        return
    today = datetime.now().date()
    if "--today" in args:
        start = today
    elif "--week" in args:
        start = today - timedelta(days=6)
    else:
        start = None

    daily = defaultdict(lambda: {
        "focus": 0, "short_break": 0, "long_break": 0,
        "starts": 0, "stops": 0, "pauses": 0, "skips": 0,
    })
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            day = e["ts"][:10]
            if start is not None and datetime.fromisoformat(day).date() < start:
                continue
            ev = e.get("event")
            if ev == "phase_end":
                daily[day][e.get("phase", "focus")] += 1
            elif ev == "start":
                daily[day]["starts"] += 1
            elif ev == "stop":
                daily[day]["stops"] += 1
            elif ev == "pause":
                daily[day]["pauses"] += 1
            elif ev == "skip":
                daily[day]["skips"] += 1
    if not daily:
        print("No matching log entries.")
        return
    print(f"{'date':<12} {'focus':>6} {'short':>6} {'long':>6} {'paused':>7} {'skip':>5} {'stop':>5} {'starts':>7}")
    totals = defaultdict(int)
    for day in sorted(daily):
        d = daily[day]
        print(
            f"{day:<12} {d['focus']:>6} {d['short_break']:>6} {d['long_break']:>6} "
            f"{d['pauses']:>7} {d['skips']:>5} {d['stops']:>5} {d['starts']:>7}"
        )
        for k, v in d.items():
            totals[k] += v
    print(
        f"{'total':<12} {totals['focus']:>6} {totals['short_break']:>6} {totals['long_break']:>6} "
        f"{totals['pauses']:>7} {totals['skips']:>5} {totals['stops']:>5} {totals['starts']:>7}"
    )


def load_tasks() -> list[dict]:
    if not TASKS_PATH.exists():
        return []
    try:
        data = json.loads(TASKS_PATH.read_text())
        return data if isinstance(data, list) else []
    except json.JSONDecodeError:
        return []


def save_tasks(tasks: list[dict]) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    tmp = TASKS_PATH.with_suffix(".tmp")
    tmp.write_text(json.dumps(tasks, indent=2) + "\n")
    tmp.replace(TASKS_PATH)


def normalize_dt(val) -> str | None:
    """Normalize a date or datetime string.

    Returns ``YYYY-MM-DD`` for a date with no time, or ``YYYY-MM-DDThh:mm``
    (local-zone) when a time is present. Returns None for empty/invalid input.
    """
    if val in (None, "", False):
        return None
    if not isinstance(val, str):
        return None
    val = val.strip()
    if not val:
        return None
    if "T" not in val and " " not in val:
        try:
            return date.fromisoformat(val).isoformat()
        except ValueError:
            return None
    try:
        dt = datetime.fromisoformat(val)
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.astimezone()
    return dt.isoformat(timespec="minutes")


TAG_RE = re.compile(r"(?:^|\s)#([A-Za-z0-9_-]+)")


def parse_tags(title: str) -> tuple[str, list[str]]:
    """Extract Todoist-style ``#tags`` from a title.

    Returns ``(clean_title, tags)`` — the title with tag tokens removed and
    whitespace collapsed, plus lowercased de-duplicated tags in first-seen order.
    """
    tags: list[str] = []
    for m in TAG_RE.finditer(title):
        tag = m.group(1).lower()
        if tag not in tags:
            tags.append(tag)
    clean = re.sub(r"\s+", " ", TAG_RE.sub(" ", title)).strip()
    return clean, tags


def normalize_tags(val) -> list[str]:
    """Coerce an explicit tags value (list of strings) into clean tag slugs."""
    if not isinstance(val, list):
        return []
    out: list[str] = []
    for t in val:
        if not isinstance(t, str):
            continue
        t = re.sub(r"[^a-z0-9_-]", "", t.strip().lstrip("#").lower())
        if t and t not in out:
            out.append(t)
    return out


def read_stdin_json() -> dict:
    if sys.stdin.isatty():
        return {}
    try:
        data = sys.stdin.read().strip()
        if not data:
            return {}
        parsed = json.loads(data)
        return parsed if isinstance(parsed, dict) else {}
    except json.JSONDecodeError:
        return {}


def find_task(tasks: list[dict], tid: int) -> dict | None:
    for t in tasks:
        if t.get("id") == tid:
            return t
    return None


def resolve_active_task(state: dict | None, tasks: list[dict]) -> dict | None:
    if state is None:
        return None
    if state.get("task_text"):
        return {"text": state["task_text"]}
    tid = state.get("task_id")
    if tid is None:
        return None
    t = find_task(tasks, tid)
    if t is None:
        return {"id": tid, "title": "(deleted task)", "deleted": True}
    return {"id": tid, "title": t.get("title", ""), "due_at": t.get("due_at"), "scheduled_at": t.get("scheduled_at")}


def cmd_tasks(args: list[str]) -> None:
    if not args:
        print("usage: pomodoro tasks {list|add|update|complete|uncomplete|delete} ...", file=sys.stderr)
        sys.exit(1)
    sub, rest = args[0], args[1:]
    if sub == "list":
        tasks = load_tasks()
        include_completed = "--include-completed" in rest or "--all" in rest
        if not include_completed:
            tasks = [t for t in tasks if not t.get("completed_at")]
        if "--tag" in rest:
            try:
                want = rest[rest.index("--tag") + 1].lstrip("#").lower()
            except IndexError:
                want = ""
            if want:
                tasks = [t for t in tasks if want in (t.get("tags") or [])]
        print(json.dumps(tasks))
        return
    if sub == "add":
        body = read_stdin_json()
        title, tags = parse_tags((body.get("title") or "").strip())
        if not title:
            print(json.dumps({"error": "title required"}), file=sys.stderr)
            sys.exit(1)
        for t in normalize_tags(body.get("tags")):
            if t not in tags:
                tags.append(t)
        tasks = load_tasks()
        new_id = max((t.get("id", 0) for t in tasks), default=0) + 1
        task = {
            "id": new_id,
            "title": title,
            "due_at": normalize_dt(body.get("due_at")),
            "scheduled_at": normalize_dt(body.get("scheduled_at")),
            "long_term": bool(body.get("long_term")),
            "tags": tags,
            "notes": (body.get("notes") or None),
            "created_at": now_iso(),
            "completed_at": None,
        }
        tasks.append(task)
        save_tasks(tasks)
        log_event("task_add", task_id=new_id, title=title)
        print(json.dumps(task))
        return
    if sub in ("update", "complete", "uncomplete", "delete"):
        if not rest:
            print(json.dumps({"error": "id required"}), file=sys.stderr)
            sys.exit(1)
        try:
            tid = int(rest[0])
        except ValueError:
            print(json.dumps({"error": "id must be integer"}), file=sys.stderr)
            sys.exit(1)
        tasks = load_tasks()
        t = find_task(tasks, tid)
        if t is None:
            print(json.dumps({"error": "not found"}), file=sys.stderr)
            sys.exit(1)
        if sub == "update":
            body = read_stdin_json()
            if "title" in body and isinstance(body["title"], str) and body["title"].strip():
                new_title, parsed_tags = parse_tags(body["title"].strip())
                if new_title:
                    t["title"] = new_title
                    t["tags"] = parsed_tags
            if "notes" in body:
                val = body["notes"]
                t["notes"] = val.strip() if isinstance(val, str) and val.strip() else None
            for field in ("due_at", "scheduled_at"):
                if field in body:
                    t[field] = normalize_dt(body[field])
            if "long_term" in body:
                t["long_term"] = bool(body["long_term"])
            if "tags" in body:
                t["tags"] = normalize_tags(body["tags"])
            log_event("task_update", task_id=tid)
        elif sub == "complete":
            t["completed_at"] = now_iso()
            log_event("task_complete", task_id=tid, title=t.get("title"))
        elif sub == "uncomplete":
            t["completed_at"] = None
            log_event("task_uncomplete", task_id=tid)
        elif sub == "delete":
            tasks = [x for x in tasks if x.get("id") != tid]
            log_event("task_delete", task_id=tid, title=t.get("title"))
        save_tasks(tasks)
        print(json.dumps(t))
        return
    print(f"unknown tasks subcommand: {sub}", file=sys.stderr)
    sys.exit(1)


def cmd_set_task() -> None:
    state = load_state()
    if state is None:
        print(json.dumps({"error": "no active pomodoro"}), file=sys.stderr)
        sys.exit(1)
    body = read_stdin_json()
    if body.get("clear"):
        state["task_id"] = None
        state["task_text"] = None
    elif "task_id" in body and body["task_id"] is not None:
        try:
            tid = int(body["task_id"])
        except (ValueError, TypeError):
            print(json.dumps({"error": "task_id must be integer"}), file=sys.stderr)
            sys.exit(1)
        state["task_id"] = tid
        state["task_text"] = None
    elif "task_text" in body and body["task_text"]:
        state["task_id"] = None
        state["task_text"] = str(body["task_text"]).strip() or None
    else:
        print(json.dumps({"error": "specify task_id, task_text, or clear"}), file=sys.stderr)
        sys.exit(1)
    save_state(state)
    log_event(
        "task_set",
        phase=state["phase"],
        task_id=state.get("task_id"),
        task_text=state.get("task_text"),
    )
    print(json.dumps({"task_id": state.get("task_id"), "task_text": state.get("task_text")}))


def cmd_pause_reason(args: list[str]) -> None:
    if not shutil.which("rofi"):
        return
    duration = 0
    if "--duration" in args:
        try:
            duration = int(args[args.index("--duration") + 1])
        except (ValueError, IndexError):
            duration = 0
    prompt = f"pause reason ({fmt_mmss(duration)})" if duration else "pause reason"
    r = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", prompt, "-l", "0", "-width", "30"],
        input="", capture_output=True, text=True,
    )
    if r.returncode != 0:
        return
    reason = r.stdout.strip()
    if not reason:
        return
    log_event("pause_reason", duration=duration, reason=reason)


def cmd_notifications(args: list[str]) -> None:
    if not shutil.which("dunstctl") or not shutil.which("rofi"):
        return
    since_id = 0
    if "--since-id" in args:
        try:
            since_id = int(args[args.index("--since-id") + 1])
        except (ValueError, IndexError):
            since_id = 0
    items = []
    for n in _dunst_history():
        nid = n.get("id", {}).get("data", 0)
        if nid <= since_id:
            continue
        appname = n.get("appname", {}).get("data", "")
        if appname == "Pomodoro":
            continue
        items.append({
            "id": nid,
            "appname": appname,
            "summary": n.get("summary", {}).get("data", ""),
            "body": n.get("body", {}).get("data", ""),
        })
    if not items:
        return
    items.sort(key=lambda x: x["id"])
    lines = []
    for i in items:
        body = " ".join(i["body"].split())
        head = f"{i['appname']}: {i['summary']}" if i["appname"] else i["summary"]
        label = f"{head} — {body}" if body else head
        lines.append(label[:240])
    chosen = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", f"backlog ({len(items)})",
         "-format", "i", "-no-custom"],
        input="\n".join(lines),
        capture_output=True,
        text=True,
    )
    if chosen.returncode != 0:
        return
    try:
        idx = int(chosen.stdout.strip())
    except ValueError:
        return
    if 0 <= idx < len(items):
        _dunstctl("history-pop", str(items[idx]["id"]))


USAGE = "usage: pomodoro {toggle|stop|skip|reset|status [--json|--i3blocks]|analyze [--today|--week|--all]|notifications [--since-id N]|pause-reason [--duration N]|tasks {list|add|update|complete|uncomplete|delete} ...|set-task}"


def main() -> None:
    cfg = load_config()
    if len(sys.argv) < 2:
        print(USAGE, file=sys.stderr)
        sys.exit(1)
    cmd, rest = sys.argv[1], sys.argv[2:]
    if cmd == "toggle":
        cmd_toggle(cfg)
    elif cmd == "stop":
        cmd_stop(cfg)
    elif cmd == "skip":
        cmd_skip(cfg)
    elif cmd == "reset":
        cmd_reset(cfg)
    elif cmd == "status":
        mode = "json" if "--json" in rest else "i3blocks" if "--i3blocks" in rest else "text"
        cmd_status(cfg, mode)
    elif cmd == "analyze":
        cmd_analyze(rest)
    elif cmd == "notifications":
        cmd_notifications(rest)
    elif cmd == "pause-reason":
        cmd_pause_reason(rest)
    elif cmd == "tasks":
        cmd_tasks(rest)
    elif cmd == "set-task":
        cmd_set_task()
    elif cmd in ("-h", "--help", "help"):
        print(__doc__)
    else:
        print(f"unknown command: {cmd}\n{USAGE}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
