        entry = append_learning(text)
        log_event("learning_add", learning_id=entry["id"])
        print(json.dumps(entry))
        return
    if sub == "list":
        if "--today" in rest:
            print(json.dumps(learnings_on(datetime.now().date().isoformat())))
        else:
            print(json.dumps(load_learnings()))
        return
    if sub == "today":
        today = datetime.now().date().isoformat()
        entries = learnings_on(today)
        print(json.dumps({
