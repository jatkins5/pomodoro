            print(json.dumps({"error": "url must start with http:// or https://"}), file=sys.stderr)
            sys.exit(1)
        sources = load_json_list(MOTD_SOURCES_PATH)
        source = {
            "id": max((s.get("id", 0) for s in sources), default=0) + 1,
            "url": url,
            "title": None,
            "added_at": now_iso(),
            "built_at": None,
            "status": "pending",
        }
        sources.append(source)
        save_json_list(MOTD_SOURCES_PATH, sources)
        print(json.dumps(source))
        return

    if sub == "sources":
        print(json.dumps(load_json_list(MOTD_SOURCES_PATH)))
        return

    if sub == "remove":
        if not rest:
            print(json.dumps({"error": "id required"}), file=sys.stderr)
            sys.exit(1)
        try:
            sid = int(rest[0])
        except ValueError:
            print(json.dumps({"error": "id must be integer"}), file=sys.stderr)
            sys.exit(1)
        sources = load_json_list(MOTD_SOURCES_PATH)
        if not any(s.get("id") == sid for s in sources):
            print(json.dumps({"error": "not found"}), file=sys.stderr)
            sys.exit(1)
        save_json_list(MOTD_SOURCES_PATH, [s for s in sources if s.get("id") != sid])
        snippets = load_json_list(MOTD_SNIPPETS_PATH)
        save_json_list(MOTD_SNIPPETS_PATH, [s for s in snippets if s.get("source_id") != sid])
        print(json.dumps({"removed": sid}))
        return

    if sub == "build":
        only = None
        if "--source" in rest:
            try:
                only = int(rest[rest.index("--source") + 1])
            except (ValueError, IndexError):
                print(json.dumps({"error": "--source needs an integer id"}), file=sys.stderr)
                sys.exit(1)
        force = "--force" in rest
        sources = load_json_list(MOTD_SOURCES_PATH)
        snippets = load_json_list(MOTD_SNIPPETS_PATH)
        next_id = max((s.get("id", 0) for s in snippets), default=0)
        built, failed = 0, 0
        for src in sources:
            if only is not None and src.get("id") != only:
                continue
            if not force and src.get("status") == "built":
                continue
            print(f"building source {src['id']}: {src['url']}", file=sys.stderr)
            try:
                text = _fetch_text(src["url"])
                if not text.strip():
                    raise RuntimeError("fetched page had no extractable text")
                result = _extract_snippets(cfg, src["url"], text)
            except Exception as e:  # noqa: BLE001 — record any failure on the source
                src["status"] = "error"
                src["error"] = str(e)
                failed += 1
                print(f"  error: {e}", file=sys.stderr)
                continue
            # Replace any prior snippets for this source.
            snippets = [s for s in snippets if s.get("source_id") != src["id"]]
            src["title"] = result.get("title")
            for snip in result.get("snippets", []):
                next_id += 1
                snippets.append({
                    "id": next_id,
                    "source_id": src["id"],
                    "source_url": src["url"],
                    "source_title": src.get("title"),
                    "phrase": snip.get("phrase", ""),
                    "context": snip.get("context", ""),
                    "why": snip.get("why", ""),
                    "created_at": now_iso(),
                })
            src["status"] = "built"
            src["built_at"] = now_iso()
            src.pop("error", None)
            built += 1
            print(f"  extracted {len(result.get('snippets', []))} passages", file=sys.stderr)
            # Persist after each source so a later failure doesn't lose earlier work.
            save_json_list(MOTD_SOURCES_PATH, sources)
            save_json_list(MOTD_SNIPPETS_PATH, snippets)
        save_json_list(MOTD_SOURCES_PATH, sources)
        save_json_list(MOTD_SNIPPETS_PATH, snippets)
        print(json.dumps({"built": built, "failed": failed, "snippets": len(snippets)}))
        return

    if sub == "current":
        snippets = load_json_list(MOTD_SNIPPETS_PATH)
        as_json = "--json" in rest
        if not snippets:
            if as_json:
                print(json.dumps({}))
            else:
                print("No message of the day yet. Add a source and run `motd build`.")
            return
        today = datetime.now().date().isoformat()
        idx = int(hashlib.sha1(today.encode()).hexdigest(), 16) % len(snippets)
        s = snippets[idx]
        chosen = {
            "phrase": s.get("phrase", ""),
            "context": s.get("context", ""),
            "why": s.get("why", ""),
            "source_url": s.get("source_url"),
            "source_title": s.get("source_title"),
        }
        if as_json:
            print(json.dumps(chosen))
        else:
            print(chosen["phrase"])
            if chosen["source_title"]:
                print(f"  — {chosen['source_title']}")
        return

    print(f"unknown motd subcommand: {sub}", file=sys.stderr)
    sys.exit(1)


def cmd_pause_reason(args: list[str]) -> None:
    if not shutil.which("rofi"):
        return
    duration = 0
    if "--duration" in args:
        try:
            duration = int(args[args.index("--duration") + 1])
        except (ValueError, IndexError):
            duration = 0
    prompt = f"pause reason ({fmt_mmss(duration)})" if duration else "pause reason"
    r = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", prompt, "-l", "0", "-width", "30"],
        input="", capture_output=True, text=True,
    )
    if r.returncode != 0:
        return
    reason = r.stdout.strip()
    if not reason:
        return
    log_event("pause_reason", duration=duration, reason=reason)


def cmd_notifications(args: list[str]) -> None:
    if not shutil.which("dunstctl") or not shutil.which("rofi"):
        return
    since_id = 0
    if "--since-id" in args:
        try:
            since_id = int(args[args.index("--since-id") + 1])
        except (ValueError, IndexError):
            since_id = 0
    items = []
    for n in _dunst_history():
        nid = n.get("id", {}).get("data", 0)
        if nid <= since_id:
            continue
        appname = n.get("appname", {}).get("data", "")
        if appname == "Pomodoro":
            continue
        items.append({
            "id": nid,
            "appname": appname,
            "summary": n.get("summary", {}).get("data", ""),
            "body": n.get("body", {}).get("data", ""),
        })
    if not items:
        return
    items.sort(key=lambda x: x["id"])
    lines = []
    for i in items:
        body = " ".join(i["body"].split())
        head = f"{i['appname']}: {i['summary']}" if i["appname"] else i["summary"]
        label = f"{head} — {body}" if body else head
        lines.append(label[:240])
    chosen = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", f"backlog ({len(items)})",
         "-format", "i", "-no-custom"],
        input="\n".join(lines),
        capture_output=True,
        text=True,
    )
    if chosen.returncode != 0:
        return
    try:
        idx = int(chosen.stdout.strip())
    except ValueError:
        return
    if 0 <= idx < len(items):
        _dunstctl("history-pop", str(items[idx]["id"]))


USAGE = "usage: pomodoro {toggle|stop|skip|reset|status [--json|--i3blocks]|analyze [--today|--week|--all]|review [--json] [--start D] [--end D]|notifications [--since-id N]|pause-reason [--duration N]|tasks {list|add|update|complete|uncomplete|delete} ...|set-task|learning {add|list|today|nudge}|motd {add|sources|remove|build|current}}"


def main() -> None:
    cfg = load_config()
    if len(sys.argv) < 2:
        print(USAGE, file=sys.stderr)
        sys.exit(1)
    cmd, rest = sys.argv[1], sys.argv[2:]
    if cmd == "toggle":
        cmd_toggle(cfg)
    elif cmd == "stop":
        cmd_stop(cfg)
    elif cmd == "skip":
        cmd_skip(cfg)
    elif cmd == "reset":
        cmd_reset(cfg)
    elif cmd == "status":
        mode = "json" if "--json" in rest else "i3blocks" if "--i3blocks" in rest else "text"
        cmd_status(cfg, mode)
    elif cmd == "analyze":
        cmd_analyze(rest)
    elif cmd == "review":
        cmd_review(cfg, rest)
    elif cmd == "notifications":
        cmd_notifications(rest)
    elif cmd == "pause-reason":
        cmd_pause_reason(rest)
    elif cmd == "tasks":
        cmd_tasks(rest)
    elif cmd == "set-task":
        cmd_set_task()
    elif cmd == "learning":
        cmd_learning(cfg, rest)
    elif cmd == "motd":
        cmd_motd(cfg, rest)
    elif cmd in ("-h", "--help", "help"):
        print(__doc__)
    else:
        print(f"unknown command: {cmd}\n{USAGE}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
