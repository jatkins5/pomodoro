def load_config() -> dict:
    if not CONFIG_PATH.exists():
        CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
        CONFIG_PATH.write_text(json.dumps(DEFAULTS, indent=2) + "\n")
        return dict(DEFAULTS)
    cfg = json.loads(CONFIG_PATH.read_text())
    merged = {**DEFAULTS, **cfg}
    merged["colors"] = {**DEFAULTS["colors"], **cfg.get("colors", {})}
    return merged


def load_state() -> dict | None:
    if not STATE_PATH.exists():
        return None
    return json.loads(STATE_PATH.read_text())


def save_state(state: dict | None) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if state is None:
        STATE_PATH.unlink(missing_ok=True)
        return
    tmp = STATE_PATH.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2))
    tmp.replace(STATE_PATH)


def iso(epoch: float) -> str:
    return datetime.fromtimestamp(epoch).astimezone().isoformat(timespec="seconds")


def now_iso() -> str:
    return iso(time.time())


def log_event(event: str, **fields) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    entry = {"ts": now_iso(), "event": event, **fields}
    with LOG_PATH.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def phase_seconds(cfg: dict, phase: str) -> int:
    return int(cfg[f"{phase}_minutes"] * 60)


def notify(cfg: dict, summary: str, body: str = "") -> None:
    if not cfg.get("notify", True):
        return
    if not shutil.which("notify-send"):
        return
    subprocess.Popen(
        ["notify-send", "-a", "Pomodoro", "--", summary, body],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def _dunstctl(*args: str) -> tuple[int, str]:
    if not shutil.which("dunstctl"):
        return 1, ""
    r = subprocess.run(
        ["dunstctl", *args], capture_output=True, text=True
    )
    return r.returncode, r.stdout


def _dunst_history() -> list[dict]:
    rc, out = _dunstctl("history")
    if rc != 0:
        return []
    try:
        return json.loads(out).get("data", [[]])[0]
    except (json.JSONDecodeError, IndexError, AttributeError):
        return []


def _max_history_id() -> int:
    return max(
        (n.get("id", {}).get("data", 0) for n in _dunst_history()),
        default=0,
    )


def enable_focus_mute() -> None:
    if not shutil.which("dunstctl"):
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if not MUTE_MARKER.exists():
        MUTE_MARKER.write_text(str(_max_history_id()))
    _dunstctl("rule", "focus_mute", "enable")


def disable_focus_mute(show_backlog: bool = False) -> None:
    if not shutil.which("dunstctl"):
        return
    _dunstctl("rule", "focus_mute", "disable")
    if not MUTE_MARKER.exists():
        return
    try:
        baseline = int(MUTE_MARKER.read_text().strip())
    except ValueError:
        baseline = 0
    MUTE_MARKER.unlink(missing_ok=True)
    if show_backlog and shutil.which("rofi"):
        subprocess.Popen(
            [str(Path(__file__).resolve()), "notifications",
             "--since-id", str(baseline)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )


def _apply_mute_for_phase(phase: str) -> None:
    if phase == "focus":
        enable_focus_mute()
    else:
        disable_focus_mute(show_backlog=True)


def _playerctl(*args: str) -> tuple[int, str]:
    if not shutil.which("playerctl"):
        return 1, ""
    r = subprocess.run(
        ["playerctl", *args], capture_output=True, text=True
    )
    return r.returncode, r.stdout


def _playing_players() -> list[str]:
    rc, out = _playerctl("--all-players", "-f", "{{playerName}}|{{status}}", "status")
    if rc != 0:
        return []
    playing = []
    for line in out.splitlines():
        line = line.strip()
        if not line or "|" not in line:
            continue
        name, _, status = line.rpartition("|")
        if status == "Playing" and name:
            playing.append(name)
    return playing


def pause_active_media() -> None:
    if not shutil.which("playerctl"):
        return
    players = _playing_players()
    if not players:
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    MEDIA_MARKER.write_text(json.dumps(players))
    for p in players:
        _playerctl("--player", p, "pause")


def resume_paused_media() -> None:
    if not shutil.which("playerctl") or not MEDIA_MARKER.exists():
        return
    try:
        players = json.loads(MEDIA_MARKER.read_text())
    except (json.JSONDecodeError, OSError):
        players = []
    MEDIA_MARKER.unlink(missing_ok=True)
    for p in players:
        _playerctl("--player", p, "play")


def _apply_media_for_phase(phase: str) -> None:
    if phase in ("short_break", "long_break"):
        pause_active_media()
    else:
        resume_paused_media()


def next_phase(state: dict, cfg: dict) -> tuple[str, int]:
    completed = state.get("completed_focuses", 0)
    if state["phase"] == "focus":
        completed += 1
        if completed % int(cfg["cycle_length"]) == 0:
            return "long_break", completed
        return "short_break", completed
    return "focus", completed


def remaining(state: dict, cfg: dict) -> int:
    if state.get("paused_at") is not None:
        return int(state["remaining_at_pause"])
    elapsed = time.time() - state["phase_started_epoch"]
    return max(0, phase_seconds(cfg, state["phase"]) - int(elapsed))


def advance_if_done(state: dict, cfg: dict) -> dict | None:
    while state is not None and state.get("paused_at") is None and remaining(state, cfg) == 0:
        ended = state["phase"]
        ended_dur = phase_seconds(cfg, ended)
        prev_task_id = state.get("task_id")
        prev_task_text = state.get("task_text")
        log_event(
            "phase_end",
            phase=ended,
            completed_focuses=state.get("completed_focuses", 0)
            + (1 if ended == "focus" else 0),
            task_id=prev_task_id,
            task_text=prev_task_text,
        )
        np, completed = next_phase(state, cfg)
        if cfg.get("auto_advance", True):
            new_start = state["phase_started_epoch"] + ended_dur
            state = {
                "phase": np,
                "phase_started_epoch": new_start,
                "completed_focuses": completed,
                "paused_at": None,
                "remaining_at_pause": None,
                "task_id": prev_task_id,
                "task_text": prev_task_text,
            }
            log_event("phase_start", phase=np, completed_focuses=completed, task_id=prev_task_id, task_text=prev_task_text)
            notify(
                cfg,
                f"{ended.replace('_', ' ').title()} complete",
                f"Starting {np.replace('_', ' ')}",
            )
            _apply_mute_for_phase(np)
            _apply_media_for_phase(np)
        else:
            log_event("stop_auto", phase=ended, completed_focuses=completed)
            notify(cfg, f"{ended.replace('_', ' ').title()} complete", "Pomodoro stopped")
            disable_focus_mute(show_backlog=(ended == "focus"))
            resume_paused_media()
            state = None
            break
    save_state(state)
    return state


def cmd_toggle(cfg: dict) -> None:
    state = load_state()
    if state is None:
        body = read_stdin_json()
        task_id = body.get("task_id")
        try:
            task_id = int(task_id) if task_id is not None else None
        except (ValueError, TypeError):
            task_id = None
        task_text = body.get("task_text")
        task_text = str(task_text).strip() if task_text else None
        if task_id is not None:
            task_text = None
        new = {
            "phase": "focus",
            "phase_started_epoch": time.time(),
            "completed_focuses": 0,
            "paused_at": None,
            "remaining_at_pause": None,
            "task_id": task_id,
            "task_text": task_text,
        }
        save_state(new)
        log_event("start", phase="focus", task_id=task_id, task_text=task_text)
        notify(cfg, "Pomodoro started", "Focus 1")
        enable_focus_mute()
        return
    state = advance_if_done(state, cfg)
    if state is None:
        cmd_toggle(cfg)
        return
    if state.get("paused_at") is None:
        rem = remaining(state, cfg)
        state["remaining_at_pause"] = rem
        state["paused_at"] = time.time()
        save_state(state)
        log_event("pause", phase=state["phase"], remaining=rem)
        notify(cfg, "Pomodoro paused", f"{state['phase'].replace('_', ' ')} — {fmt_mmss(rem)} left")
        disable_focus_mute(show_backlog=False)
    else:
        pause_dur = time.time() - state["paused_at"]
        state["phase_started_epoch"] += pause_dur
        state["paused_at"] = None
        state["remaining_at_pause"] = None
        save_state(state)
        log_event("resume", phase=state["phase"], pause_duration=int(pause_dur))
        notify(cfg, "Pomodoro resumed", state["phase"].replace("_", " "))
        if state["phase"] == "focus":
            enable_focus_mute()
        if int(pause_dur) > 10 and shutil.which("rofi"):
            subprocess.Popen(
                [str(Path(__file__).resolve()), "pause-reason",
                 "--duration", str(int(pause_dur))],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )


def cmd_stop(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    log_event(
        "stop",
        phase=state["phase"],
        completed_focuses=state.get("completed_focuses", 0),
        remaining=remaining(state, cfg),
        task_id=state.get("task_id"),
        task_text=state.get("task_text"),
    )
    save_state(None)
    notify(cfg, "Pomodoro stopped")
    disable_focus_mute(show_backlog=False)
    resume_paused_media()


def cmd_skip(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    ended = state["phase"]
    completed_so_far = state.get("completed_focuses", 0) + (1 if ended == "focus" else 0)
    log_event("skip", phase=ended, completed_focuses=completed_so_far)
    np, completed = next_phase(state, cfg)
    new = {
        "phase": np,
        "phase_started_epoch": time.time(),
        "completed_focuses": completed,
        "paused_at": None,
        "remaining_at_pause": None,
        "task_id": state.get("task_id"),
        "task_text": state.get("task_text"),
    }
    save_state(new)
    log_event("phase_start", phase=np, completed_focuses=completed, task_id=new.get("task_id"), task_text=new.get("task_text"))
    notify(cfg, f"Skipped to {np.replace('_', ' ')}")
    _apply_mute_for_phase(np)
    _apply_media_for_phase(np)


def cmd_reset(cfg: dict) -> None:
    state = load_state()
    if state is None:
        return
    log_event("reset", phase=state["phase"])
    state["phase_started_epoch"] = time.time()
    if state.get("paused_at") is not None:
        state["paused_at"] = time.time()
        state["remaining_at_pause"] = phase_seconds(cfg, state["phase"])
    save_state(state)
    notify(cfg, f"{state['phase'].replace('_', ' ').title()} reset")
    if state["phase"] == "focus":
        enable_focus_mute()


def fmt_mmss(seconds: int) -> str:
    m, s = divmod(int(seconds), 60)
    return f"{m:02d}:{s:02d}"


def focuses_completed_on(date_str: str) -> int:
    if not LOG_PATH.exists():
        return 0
    count = 0
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line or not line.startswith("{"):
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            if (
                e.get("event") == "phase_end"
                and e.get("phase") == "focus"
                and e.get("ts", "").startswith(date_str)
            ):
                count += 1
    return count


def cmd_status(cfg: dict, mode: str) -> None:
    state = load_state()
    if state is not None:
        state = advance_if_done(state, cfg)
    today = datetime.now().date().isoformat()
    focuses_today = focuses_completed_on(today)
    if state is None:
        if mode == "json":
            print(json.dumps({"status": "idle", "focuses_today": focuses_today, "task": None}))
        elif mode == "i3blocks":
            pass
        else:
            print(f"idle ({focuses_today} today)" if focuses_today else "idle")
        return
    rem = remaining(state, cfg)
    paused = state.get("paused_at") is not None
    color = cfg["colors"]["paused"] if paused else cfg["colors"][state["phase"]]
    text = fmt_mmss(rem)
    if mode == "json":
        print(json.dumps({
            "status": "paused" if paused else "running",
            "phase": state["phase"],
            "remaining": rem,
            "text": text,
            "color": color,
            "completed_focuses": state.get("completed_focuses", 0),
            "cycle_length": int(cfg["cycle_length"]),
            "focuses_today": focuses_today,
            "task": resolve_active_task(state, load_tasks()),
        }))
    elif mode == "i3blocks":
        print(text)
        print(text)
        print(color)
    else:
        cycle = int(cfg["cycle_length"])
        done = state.get("completed_focuses", 0)
        label = state["phase"].replace("_", " ")
        suffix = " (paused)" if paused else ""
        print(f"{label} {text} — {done % cycle if state['phase'] == 'focus' else done}/{cycle}{suffix}")


def cmd_analyze(args: list[str]) -> None:
    if not LOG_PATH.exists():
        print("No log yet.")
        return
    today = datetime.now().date()
    if "--today" in args:
        start = today
    elif "--week" in args:
        start = today - timedelta(days=6)
    else:
        start = None

    daily = defaultdict(lambda: {
        "focus": 0, "short_break": 0, "long_break": 0,
        "starts": 0, "stops": 0, "pauses": 0, "skips": 0,
    })
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            day = e["ts"][:10]
            if start is not None and datetime.fromisoformat(day).date() < start:
                continue
            ev = e.get("event")
            if ev == "phase_end":
                daily[day][e.get("phase", "focus")] += 1
            elif ev == "start":
                daily[day]["starts"] += 1
            elif ev == "stop":
                daily[day]["stops"] += 1
            elif ev == "pause":
                daily[day]["pauses"] += 1
            elif ev == "skip":
                daily[day]["skips"] += 1
    if not daily:
        print("No matching log entries.")
        return
    print(f"{'date':<12} {'focus':>6} {'short':>6} {'long':>6} {'paused':>7} {'skip':>5} {'stop':>5} {'starts':>7}")
    totals = defaultdict(int)
    for day in sorted(daily):
        d = daily[day]
        print(
            f"{day:<12} {d['focus']:>6} {d['short_break']:>6} {d['long_break']:>6} "
            f"{d['pauses']:>7} {d['skips']:>5} {d['stops']:>5} {d['starts']:>7}"
        )
        for k, v in d.items():
            totals[k] += v
    print(
        f"{'total':<12} {totals['focus']:>6} {totals['short_break']:>6} {totals['long_break']:>6} "
        f"{totals['pauses']:>7} {totals['skips']:>5} {totals['stops']:>5} {totals['starts']:>7}"
    )


def default_week_range() -> tuple[str, str]:
    """The most recently completed Sunday->Saturday week, as ISO date strings.

    A Sun-Sat week counts as complete once its Saturday has passed. Run on a
    Sunday this is the week that just ended; run on a Saturday it is the
    week before (the current one is not done yet).
    """
    today = date.today()
    # weekday(): Mon=0 .. Sat=5 .. Sun=6. Days back to the last *finished* Saturday.
    back = (today.weekday() - 5) % 7 or 7
    end = today - timedelta(days=back)
    start = end - timedelta(days=6)
    return start.isoformat(), end.isoformat()


def _events_in_range(start: str, end: str):
    """Yield log events whose date (ts[:10]) falls within [start, end] inclusive."""
    if not LOG_PATH.exists():
        return
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line or not line.startswith("{"):
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            if start <= e.get("ts", "")[:10] <= end:
                yield e


_REVIEW_PRUNE = {
    "node_modules", ".cache", ".cargo", ".rustup", ".npm", ".venv", "venv",
    "__pycache__", ".local", ".mozilla", "snap", "Calibre Library",
}


def find_git_repos(root: Path, excludes: list[str], max_depth: int) -> list[Path]:
    """Walk ``root`` and return git working-tree roots, not descending into one
    once found. Hidden and heavy directories are pruned to keep the scan quick."""
    root = root.expanduser()
    repos: list[Path] = []
    root_depth = len(root.parts)
    for dirpath, dirnames, _ in os.walk(root):
        p = Path(dirpath)
        if len(p.parts) - root_depth >= max_depth:
            dirnames[:] = []
            continue
        if ".git" in dirnames:
            repos.append(p)
            dirnames[:] = []  # a repo's subdirectories are part of that repo
            continue
        dirnames[:] = [
            d for d in dirnames
            if d not in _REVIEW_PRUNE
            and not d.startswith(".")
            and not any(ex in str(p / d) for ex in excludes)
        ]
    return repos


def repo_commits(repo: Path, emails: list[str], branches: list[str], start: str, end: str) -> list[dict]:
    """Commits in ``repo`` reachable from ``branches`` within [start, end]
    inclusive, authored by one of ``emails`` (or anyone if empty). Matches both
    local branches and remote-tracking ones (e.g. ``staging`` and
    ``origin/staging``) so merged work shows even when the local ref is stale."""
    wanted_branches = set(branches)
    try:
        found = subprocess.run(
            ["git", "-C", str(repo), "for-each-ref", "--format=%(refname)",
             "refs/heads", "refs/remotes"],
            capture_output=True, text=True, timeout=10,
        )
    except (subprocess.TimeoutExpired, OSError):
        return []
    # Keep refs whose final path component is a configured branch name.
    refs = [r.strip() for r in found.stdout.splitlines()
            if r.strip().rsplit("/", 1)[-1] in wanted_branches]
    if not refs:
        return []
    sep = "\x1f"
    fmt = sep.join(["%h", "%aI", "%aE", "%s"])
    args = [
        "git", "-C", str(repo), "log", *refs, "--no-merges",
        f"--since={start} 00:00:00", f"--until={end} 23:59:59",
        f"--pretty=format:{fmt}",
    ]
    for em in emails:
        args.append(f"--author={em}")
    try:
        proc = subprocess.run(args, capture_output=True, text=True, timeout=20)
    except (subprocess.TimeoutExpired, OSError):
        return []
    if proc.returncode != 0:
        return []
    wanted = {em.lower() for em in emails}
    out: list[dict] = []
    seen: set[str] = set()
    for line in proc.stdout.splitlines():
        parts = line.split(sep)
        if len(parts) != 4:
            continue
        h, aiso, aemail, subject = parts
        if h in seen:
            continue
        if aiso[:10] < start or aiso[:10] > end:
            continue
        if wanted and aemail.lower() not in wanted:
            continue
        seen.add(h)
        out.append({"hash": h, "date": aiso, "email": aemail, "subject": subject})
    return out


def workclock_summary(cfg: dict, start: str, end: str) -> dict:
    """Hours worked and earnings from the ~/.workclock.log (START,/STOP, lines)
    for sessions whose start date falls within [start, end] inclusive."""
    rate = float(cfg.get("workclock_rate", 75))
    log_path = Path(cfg.get("workclock_log") or (Path.home() / ".workclock.log")).expanduser()
    active_path = Path(cfg.get("workclock_active") or (Path.home() / ".workclock.active")).expanduser()
    by_day: dict[str, float] = {}
    total = 0.0

    def add(begin: datetime, finish: datetime) -> None:
        nonlocal total
        day = begin.date().isoformat()
        if not (start <= day <= end):
            return
        secs = (finish - begin).total_seconds()
        if secs > 0:
            total += secs
            by_day[day] = by_day.get(day, 0.0) + secs

    if log_path.exists():
        cur: datetime | None = None
        for line in log_path.read_text().splitlines():
            action, _, ts = line.strip().partition(",")
            if not ts:
                continue
            try:
                dt = datetime.fromisoformat(ts.strip())
            except ValueError:
                continue
            if action == "START":
                cur = dt
            elif action == "STOP" and cur is not None:
                add(cur, dt)
                cur = None
    # A session in progress has a START in the log with no STOP yet; count it up to now.
    if active_path.exists():
        try:
            begin = datetime.fromisoformat(active_path.read_text().strip())
        except ValueError:
            begin = None
        if begin is not None:
            add(begin, datetime.now())

    return {
        "total_seconds": int(total),
        "hours": round(total / 3600, 2),
        "earnings": round(total / 3600 * rate, 2),
        "rate": rate,
        "by_day": {d: int(s) for d, s in by_day.items()},
    }


def build_review(cfg: dict, start: str, end: str) -> dict:
    by_day: dict[str, int] = {}
    pomodoros = 0
    for e in _events_in_range(start, end):
        if e.get("event") == "phase_end" and e.get("phase") == "focus":
            pomodoros += 1
            d = e["ts"][:10]
            by_day[d] = by_day.get(d, 0) + 1

    tasks_done = [
        {"title": t.get("title", ""), "tags": t.get("tags") or [], "completed_at": ca}
        for t in load_tasks()
        if (ca := t.get("completed_at")) and start <= ca[:10] <= end
    ]
    tasks_done.sort(key=lambda x: x["completed_at"])

    learns = [
        {"text": e.get("text", ""), "ts": e.get("ts", "")}
        for e in load_learnings()
        if start <= e.get("ts", "")[:10] <= end
    ]

    emails = [e for e in (cfg.get("review_author_emails") or []) if isinstance(e, str)]
    branches = [b for b in (cfg.get("review_branches") or []) if isinstance(b, str)]
    root = Path(cfg.get("review_root") or Path.home())
    excludes = [x for x in (cfg.get("review_excludes") or []) if isinstance(x, str)]
    depth = int(cfg.get("review_scan_depth", 4))
    groups: list[dict] = []
    total_commits = 0
    for repo in find_git_repos(root, excludes, depth):
        cs = repo_commits(repo, emails, branches, start, end)
        if not cs:
            continue
        total_commits += len(cs)
        try:
            name = str(repo.relative_to(Path.home()))
        except ValueError:
            name = str(repo)
        groups.append({"repo": name, "path": str(repo), "count": len(cs), "commits": cs})
    groups.sort(key=lambda g: (-g["count"], g["repo"]))

    return {
        "start": start,
        "end": end,
        "work": workclock_summary(cfg, start, end),
        "pomodoros": {"total": pomodoros, "by_day": by_day},
        "tasks": tasks_done,
        "learnings": learns,
        "commits": {"total": total_commits, "repos": groups},
    }


